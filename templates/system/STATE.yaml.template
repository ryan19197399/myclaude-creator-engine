# STATE.yaml — Runtime state for {{SYSTEM_NAME}}
# WHY: Central state file read by CLAUDE.md on every boot. Tracks session continuity.
# WHY: Agents update this after routing decisions so the next invocation has context.
# RULE: Never delete entries — append only. Truncate history to last 10 if file exceeds 200 lines.

version: "{{VERSION}}"
system: "{{PRODUCT_SLUG}}"
description: "{{SYSTEM_DESCRIPTION}}"

components:
  # WHY: Declare all system components here for runtime discovery.
  # Each component needs: name, type, path, status.
  # status options: active | disabled | degraded
  # Example:
  # - name: analysis-skill
  #   type: skill
  #   path: skills/analysis/
  #   status: active

session:
  current: null       # Active session ID or null
  last_intent: null   # Last routed intent
  last_component: null  # Last component invoked
  history: []         # Append session IDs here. Keep last 10.
  # Example entry:
  # - id: "2026-04-04-001"
  #   intent: "{{INTENT_1}}"
  #   component: "{{COMPONENT_A}}"
  #   timestamp: "2026-04-04T22:00:00Z"
  #   outcome: "success"

degraded_components: []
  # WHY: List component names here if they fail. CLAUDE.md checks this before routing.
  # Cleared manually or by /reset command.
