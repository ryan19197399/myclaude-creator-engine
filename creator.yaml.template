---
# MyClaude Creator Profile Template
# Copy to creator.yaml and fill in your details
# Generated by: /onboard command

schema_version: 2

creator:
  name: "your-username"
  myclaude_username: "@your-username"
  display_name: "Your Display Name"
  communication_language: "en"  # Language for Engine interaction
  document_language: "en"       # Language for published product content

profile:
  type: "developer"  # developer | prompt-engineer | domain-expert | marketer | operator | agency | hybrid
  expertise:
    - "your-expertise-area"
  technical_level: "intermediate"  # beginner | intermediate | expert

preferences:
  default_mcs_target: "MCS-1"
  default_license: "MIT"
  pricing_strategy: "free"  # free | freemium | premium
  preferred_categories:
    - "productivity"

# Usage patterns (auto-updated by Engine — do not edit manually)
usage:
  products_created: 0
  products_published: 0
  most_created_type: null         # Tracks which type they create most
  common_dna_gaps: []             # DNA patterns that consistently score low
  sessions_count: 0
  last_session: null
