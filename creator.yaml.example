# Example creator profile — generated by /onboard
# Copy to creator.yaml and customize, or run /onboard for guided setup

creator:
  name: "Your Name"
  myclaude_username: "@yourhandle"
  language: "en"
  onboarded_at: "2026-03-26"

  profile:
    type: "developer"  # developer | prompt-engineer | domain-expert | marketer | agency | hybrid
    expertise:
      - "Python automation"
      - "Security auditing"
    technical_level: "advanced"  # beginner | intermediate | advanced | expert
    goals:
      - "Sell products for income"
      - "Share free tools with the community"

  preferences:
    default_license: "MIT"  # MIT | Apache-2.0 | GPL-3.0 | Proprietary | etc.
    default_category: "skills"
    pricing_strategy: "freemium"  # free | freemium | premium
    quality_target: "MCS-2"  # MCS-1 | MCS-2 | MCS-3

  inventory:
    local_skills: 0
    local_agents: 0
    published_products: 0
    unpublished_drafts: 0

  recommendations:
    suggested_categories: ["skills", "agents"]
    market_gaps_matched: []
